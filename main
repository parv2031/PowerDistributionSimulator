using namespace std;

// --- Global Variable  START---
int resident_demand, hospital_demand, industry_demand, institute_demand;
static random_device rd;
static mt19937 g(rd());
// --- Global Variable END---

// vertex for power plant and substation
class Vertix_A
{

public:
    string node_type = "";           // Type
    float max_limit;                 // maximum load capacity of the substation and power plant
    float current_downstream_demand; // Tracks actual load
    int x, y;                        // Coordinates

    // Constructor
    vertex_A(string type) : node_type(type), max_limit(0), current_downstream_demand(0), x(0), y(0)
    {
    }
};

// vertex for consumers (mainly resident, hospital ,institute ,industry)
class Vertix_B
{
public:
    int demand;
    string node_type; // <-- Type
    int x, y;         // <-- Coordinates

    // Constructor
    vertex_B(string type) : node_type(type), x(0), y(0)
    {
        if (type == "residential")
            demand = resident_demand;
        else if (type == "industrial")
            demand = industry_demand;
        else if (type == "institute")
            demand = institute_demand;
        else
            demand = hospital_demand;
    }
};
class Graph{
public:
    unordered_map<Vertix_A *, vector<pair<Vertix_B *, Edge *>>> adj_substion_consumer; // adj list of substation to consumers
    unordered_map<Vertix_A *, vector<pair<Vertix_A *, Edge *>>> adj_power_substation;  // adj list of substation to substaiton and power_plant to substations
private:
    vector<int> distributor(int total_count, int divide_count)
    {
        if (divide_count <= 0)
            return {};
        vector<int> weights(divide_count);
        int weightconsumers = 0;
        int base = total_count / divide_count;
        int minWeight = max(1, base - (3 * base) / 10); // 30% less than average
        int maxWeight = max(1, base + (3 * base) / 10); // 30% more than average
        for (int i = 0; i < divide_count; i++)
        {
            weights[i] = rand() % (maxWeight - minWeight + 1) + minWeight;
            weightconsumers += weights[i];
        }

        if (weightconsumers == 0)
        { // Avoid divide by zero
            for (int i = 0; i < divide_count; i++)
                weights[i] = 1;
            weightconsumers = divide_count;
        }

        vector<int> distribution(divide_count);
        int distributedconsumers = 0;
        for (int i = 0; i < divide_count - 1; i++)
        {
            distribution[i] = (long long)weights[i] * total_count / weightconsumers;
            distributedconsumers += distribution[i];
        }
        distribution[divide_count - 1] = total_count - distributedconsumers;
        return distribution;
    }
    // Helper function for mapping
    int mapping_helper(Vertix_A *&substation, vector<pair<Vertix_B *, Edge *>> &connect, const string &type, int count, int demand)
    {
        for (int i = 0; i < count; i++)
        {
            Vertix_B *node = new Vertix_B(type);
            demand += node->demand;
            Edge *edge = new Edge(substation, node);
            connect.push_back({node, edge});
        }
        return demand;
    }
public:
    void substation_consumer_mapping(Vertix_A *substation, int consumers)
    {
        int hospital_count = 0.2f * consumers;
        int industrial_count = 0.1f * consumers;
        int institute_count = 0.2f * consumers;
        int resident_count = consumers - (hospital_count + industrial_count + institute_count);

        int total_demand = 0;
        vector<pair<vertex_B *, Edge *>> connect;                                                          // contains vertices along with edges to be mapped to substation
        total_demand += mapping_helper(substation, connect, "hospital", hospital_count, total_demand);     // hospitals
        total_demand += mapping_helper(substation, connect, "industrial", industrial_count, total_demand); // industries
        total_demand += mapping_helper(substation, connect, "institute", institute_count, total_demand);   // institutes
        total_demand += mapping_helper(substation, connect, "residential", resident_count, total_demand);  // residents

        substation->max_limit = total_demand * 1.5f;          // Node's max capacity (150% of demand)
        substation->current_downstream_demand = total_demand; // Node's current load

        adj_substion_consumer[substation] = connect;
    }
    void mapping(int powerplant, int substation, int consumer)
    {
        vector<vertex_A *> powerplants;
        for (int i = 0; i < powerplant; i++)
        {
            powerplants.push_back(new Vertix_A("power_plant"));
        }
        vector<Vertix_A *> Substations;
        vector<int> substations = distributor(consumer, substation);
        for (auto val : substations)
        {
            Vertix_A *sub = new Vertix_A("substation");
            substation_consumer_mapping(sub, val);
            Substations.push_back(sub);
        }
        powerplant_substation_mapping(powerplants, Substations);
    }

    void powerplant_substation_mapping(vector<Vertix_A *> &powerplants, vector<Vertix_A *> &substations)
    {
        int powerplant_count = powerplants.size();
        int substation_count = substations.size();

        int substations_for_powerplants = (int)(0.4f * substation_count);                     // 40 percentage of substations connected directly to power plants
        if (substation_count > 0 && powerplant_count > 0 && substations_for_powerplants == 0) // For security
        {
            substations_for_powerplants = 1;
        }
        vector<int> substation_indices(substation_count);
        iota(substation_indices.begin(), substation_indices.end(), 0); // iota --> fill the vector with sequential values starting from 1
        shuffle(substation_indices.begin(), substation_indices.end(), g);
        int idx = 0;

        // --- 1. Connect Power Plants to primary Substations ---
        for (int i = 0; i < substations_for_powerplants; i++)
        {
            Vertix_A *plant = powerplants[i % powerplant_count];
            Vertix_A *sub = substations[substation_indices[idx]];
            Edge *edge = new Edge(plant, sub);

            // Set edge loads based on the child substation
            edge->current_load = sub->current_downstream_demand;
            edge->max_load = 2 * sub->max_limit;

            adj_power_substation[plant].push_back({sub, edge});
        }
        while (idx < substation_count)
        {
            if (idx == 0)
                break;
            int src_idx = rand() % idx;                               // Picks any previously placed parent
            Vertix_A *src = substations[substation_indices[src_idx]]; // Parent substation (can be primary or secondary)
            Vertix_A *dest = substations[substation_indices[idx]];    // Child substation
            Edge *edge = new Edge(src, dest);

            // Propagate loads up the tree
            src->max_limit += dest->max_limit;                                 // Parent's limit must accommodate the child's limit
            src->current_downstream_demand += dest->current_downstream_demand; // Parent's load increases

            // Set edge loads based on the child substation
            edge->current_load = dest->current_downstream_demand;
            edge->max_load = dest->max_limit;

            adj_power_substation[src].push_back({dest, edge});
            idx++;
        }

        // --- 3. Set Power Plant total limits based on their children ---
        for (auto &plant_entry : adj_power_substation)
        {
            Vertix_A *plant = plant_entry.first;
            if (plant->node_type != "power_plant")
                continue;

            float sum_substation_limits = 0;
            float sum_substation_demands = 0;

            for (auto &pair : plant_entry.second)
            {
                Vertix_A *sub = pair.first; // This is a direct child substation
                sum_substation_limits += sub->max_limit;
                sum_substation_demands += sub->current_downstream_demand;
            }
            plant->max_limit = sum_substation_limits * 1.5f; // 150% of all substation's limit
            plant->current_downstream_demand = sum_substation_demands;
        }
    }
};

// --- NEW: Define Game States ---
enum GameState
{
    STATE_INPUT,
    STATE_VISUALIZATION
};

// --- RAYLIB MAIN FUNCTION ---
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    srand((unsigned int)time(0)); // Seed random number generator

    // --- 1. Initialize Raylib Window ---
    const int screenWidth = 1280;
    const int screenHeight = 720;
    InitWindow(screenWidth, screenHeight, "Power Grid Visualizer");

    // --- 2. Define States ---
    GameState currentState = STATE_INPUT;

    // --- 3. Variables for STATE_INPUT (Using basic Raylib) ---
    const int inputFieldCount = 7;
    const char *labels[inputFieldCount] = {
        "Power Plants:", "Substations:", "Consumers:",
        "Resident Demand:", "Hospital Demand:", "Industrial Demand:", "Institute Demand:"};
    Rectangle textBoxes[inputFieldCount];
    string inputStrings[inputFieldCount];
    int activeTextBox = -1;          // Index of the currently selected text box, -1 for none

    // Set default values for the strings
    inputStrings[0] = "3";
    inputStrings[1] = "18";
    inputStrings[2] = "100"; // scaled by 1/9
    inputStrings[3] = "10";
    inputStrings[4] = "100";
    inputStrings[5] = "500";
    inputStrings[6] = "80";

    Rectangle startButton;
    bool showCursor = false;
    int framesCounter = 0;

    // Layout for input screen
    int startY = 100;
    int inputHeight = 40;
    int inputWidth = 200;
    int labelWidth = 250;
    int padding = 15;
    int fontSize = 20;

    for (int i = 0; i < inputFieldCount; i++)
    {
        textBoxes[i] = {(float)screenWidth / 2 - inputWidth / 2, (float)startY + i * (inputHeight + padding), (float)inputWidth, (float)inputHeight};
    }
    startButton = {(float)screenWidth / 2 - inputWidth / 2, (float)startY + inputFieldCount * (inputHeight + padding) + 20, (float)inputWidth, (float)inputHeight + 10};
    // --- 4. Variables for STATE_VISUALIZATION ---
graph G; // Create graph object
Camera2D camera = {0};
const float ZOOM_LOD_SUBSTATION = 0.5f;
const float ZOOM_LOD_CONSUMER = 1.0f;
graph::Vertix_A *selected_a_node = nullptr;
graph::Vertix_B *selected_b_node = nullptr;
graph::Edge *selected_edge = nullptr;
unordered_set<void *> visited_nodes;
vector<graph::Vertix_A *> a_nodes_to_draw;
vector<graph::Vertix_B *> b_nodes_to_draw;

// --- NEW: Variables for timed highlighting ---
enum FixVizState
{
    VIZ_IDLE,
    VIZ_SHOWING_OVERLOAD,
    VIZ_SHOWING_FIX
};
FixVizState fix_viz_state = VIZ_IDLE;
double fix_highlight_start_time = 0.0; // Time when overload highlight started
